{
/* header opcional */
}

let digit = ['0'-'9']
let ws = [' ' '\t' '\n']+

rule gettoken [lexbuf] =
    ws { return lexbuf; }
  | digit+ { return NUMBER; }
  | '+' { return PLUS; }
  | '-' { return MINUS; }
  | '*' { return TIMES; }
  | '/' { return DIV; }
  | '(' { return LPAREN; }
  | ')' { return RPAREN; }
  | eof { return EOF; }

{
/* trailer opcional */
}
