digraph RegexTree {
  rankdir=TB;
  node [shape=box, fontname="Helvetica"];
  n0 [label="TOKENS"];
  n1 [label="TOKEN SKIP"];
  n0 -> n1;
  n2 [label="+"];
  n3 [label="set(0x09,0x0A,' ')"];
  n2 -> n3;
  n1 -> n2;
  n4 [label="TOKEN NUMBER"];
  n0 -> n4;
  n5 [label="+"];
  n6 [label="set('0','1','2','3','4','5','6','7',...)"];
  n5 -> n6;
  n4 -> n5;
  n7 [label="TOKEN PLUS"];
  n0 -> n7;
  n8 [label="set('+')"];
  n7 -> n8;
  n9 [label="TOKEN MINUS"];
  n0 -> n9;
  n10 [label="set('-')"];
  n9 -> n10;
  n11 [label="TOKEN TIMES"];
  n0 -> n11;
  n12 [label="set('*')"];
  n11 -> n12;
  n13 [label="TOKEN DIV"];
  n0 -> n13;
  n14 [label="set('/')"];
  n13 -> n14;
  n15 [label="TOKEN LPAREN"];
  n0 -> n15;
  n16 [label="set('(')"];
  n15 -> n16;
  n17 [label="TOKEN RPAREN"];
  n0 -> n17;
  n18 [label="set(')')"];
  n17 -> n18;
  n19 [label="TOKEN EOF (eof)"];
  n0 -> n19;
}
